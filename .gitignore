# ── Data ───────────────────────────────────────────────
# Kaggle data is 2.6 GB — never commit. README explains how to get it.
data/raw/
data/interim/
data/processed/

# ── Virtual environment ────────────────────────────────
.venv/
venv/
env/

# ── MLflow tracking store ──────────────────────────────
# SQLite db + all run folders (contain model files + plots). Reviewers
# regenerate locally by running the notebooks in order.
artifacts/mlruns/
artifacts/mlflow.db

# ── Generated pipeline artifacts ───────────────────────
# Regenerated by running Step 1 → Step 5. Keep the directory but ignore
# its contents.
artifacts/*
!artifacts/.gitkeep

# ── Python ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Jupyter ────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── OS noise ───────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE / editor ───────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── Local secrets / env files ──────────────────────────
.env
.env.local
*.key
